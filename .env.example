# =============================================================================
# MERLIN (Airdale) Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# Anthropic API key for Claude inference (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ElevenLabs API key for text-to-speech (required for voice)
ELEVENLABS_API_KEY=your-key-here

# -----------------------------------------------------------------------------
# Claude Settings
# -----------------------------------------------------------------------------

# Claude model to use for inference
CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens for Claude responses (keeps comms tactical)
CLAUDE_MAX_TOKENS=1024

# Max tokens for briefings, checklists, and flight plans
CLAUDE_MAX_TOKENS_BRIEFING=2048

# Max message pairs to retain in conversation history
CLAUDE_MAX_HISTORY=20

# Temperature for Claude responses (0.0 - 1.0)
CLAUDE_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# SimConnect Bridge
# -----------------------------------------------------------------------------

# WebSocket host for the SimConnect bridge
# NOTE: If running in WSL2, set this to your Windows host IP (e.g., 172.x.x.x),
# not "localhost". Find it with: powershell.exe -c "ipconfig" | grep IPv4
SIMCONNECT_WS_HOST=localhost

# WebSocket port for the SimConnect bridge
SIMCONNECT_WS_PORT=8765

# Telemetry polling interval in milliseconds
SIMCONNECT_POLL_INTERVAL_MS=100

# -----------------------------------------------------------------------------
# Voice Pipeline -- Speech-to-Text (Whisper)
# -----------------------------------------------------------------------------

# Whisper model size: tiny.en, base.en, small, small.en, medium.en, large-v3
WHISPER_MODEL=small

# Audio input device index (leave blank for system default)
AUDIO_INPUT_DEVICE=

# Voice activity detection sensitivity (0.0 - 1.0, higher = more sensitive)
VAD_SENSITIVITY=0.6

# Wake word -- say this to activate MERLIN (leave blank for always-on)
WAKE_WORD=merlin

# -----------------------------------------------------------------------------
# Voice Pipeline -- Text-to-Speech (ElevenLabs)
# -----------------------------------------------------------------------------

# ElevenLabs voice ID for MERLIN's voice
ELEVENLABS_VOICE_ID=

# ElevenLabs model ID
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Voice stability (0.0 - 1.0)
ELEVENLABS_STABILITY=0.5

# Voice similarity boost (0.0 - 1.0)
ELEVENLABS_SIMILARITY_BOOST=0.75

# Voice style (0.0 - 1.0, higher = more expressive)
ELEVENLABS_STYLE=0.3

# -----------------------------------------------------------------------------
# Context Store (ChromaDB)
# -----------------------------------------------------------------------------

# Directory for ChromaDB persistent storage
CHROMA_PERSIST_DIR=./chroma_data

# Embedding model for document chunks
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of chunks to retrieve per RAG query
RAG_TOP_K=5

# Chunk size in characters for document splitting
RAG_CHUNK_SIZE=1000

# Chunk overlap in characters
RAG_CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# FAA Data Service
# -----------------------------------------------------------------------------

# Aviation API base URL for airport/weather lookups
AVIATION_API_BASE_URL=https://api.aviationapi.com/v1

# Cache TTL for airport data in seconds (default: 1 hour)
AIRPORT_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Screen Capture (Optional -- Phase 5)
# -----------------------------------------------------------------------------

# Enable screen capture for Claude Vision
SCREEN_CAPTURE_ENABLED=false

# Capture interval in seconds (lower = more API cost)
SCREEN_CAPTURE_INTERVAL=2.0

# Target resolution for captured frames (width)
SCREEN_CAPTURE_WIDTH=1280

# MSFS window title for capture targeting
SCREEN_CAPTURE_WINDOW_TITLE=Microsoft Flight Simulator

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./logs

# Log conversation transcripts
LOG_TRANSCRIPTS=true
